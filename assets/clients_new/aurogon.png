            background: url(./imgs/tab1_btn2.png) no-repeat 50% 0/100% 100%;
        }

        .pg2_tabs1_btn2.on {
            background: url(./imgs/tab1_btn2_h.png) no-repeat 50% 0/100% 100%;
        }

        .pg2_tab_cont {
            display: none;
